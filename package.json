{
  "name": "mpl-vscode",
  "displayName": "MPL",
  "version": "0.0.0-dev",
  "publisher": "axiomhq",
  "description": "VS Code language support for Axiom Metrics Processing Language (MPL)",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/axiomhq/mpl.git",
    "directory": "packages/mpl-vscode"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "mpl",
    "axiom",
    "language-server",
    "lsp"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onLanguage:mpl"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "language-configuration.json",
    "syntaxes",
    "server",
    "README.md",
    "LICENSE",
    "LICENSE-APACHE",
    "LICENSE-MIT"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mpl",
        "aliases": [
          "MPL",
          "mpl"
        ],
        "extensions": [
          ".mpl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mpl",
        "scopeName": "source.mpl",
        "path": "./syntaxes/mpl.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "files.associations": {
        "*.mpl": "mpl"
      }
    }
  },
  "scripts": {
    "check": "tsc -p . --noEmit",
    "build": "vite build",
    "watch": "tsc -w -p .",
    "stage": "node ./scripts/stage-server.mjs",
    "package": "vsce package --no-dependencies --allow-unused-files-pattern"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
